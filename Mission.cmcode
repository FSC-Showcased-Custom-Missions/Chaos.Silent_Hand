asicOperatorBadge"] = "A badge that gives limited access to areas.",&n&n&t&t["Item.Blowtorch"] = "Blowtorch",&n&t&t["ItemDesc.Blowtorch"] = "It's a Blowtorch, what do you think it does?",&n&n&t&t["Sofia.Server"] = "Download the servers info and optionally inject the spyware.",&n&t&t["Title.ServerDownload"] = "Download Server Contents",&n&t&t["Operator.Any.Vault1"] ="Sparrow didn't u say the cash would have been delivered? \n Theres only 1 bag here.",&n&t&t["Sofia.Any.Vault1"] ="There isn't? \n Maybe look at the Loading Bay if there is the Truck",&n&n&t&t["Operator.Any.MissionStarted"] ="Alright, I am here. So what is this place?",&n&t&t["Sofia.MissionStarted"] = "An old Halycon Facility, we discovered a while back.",&n&t&t--["Operator.Any.MissionStarted1"] = "Why am I here then?",&n&t&t["Sofia.MissionStarted1"] = "I send you here so you can try find some files. \n Nothing special.",&n&t&t["Operator.Any.MissionStarted2"] = "Are you sure it's abandoned?",&n&t&t["Sofia.MissionStarted2"] = "Ye? Everything alright?",&n&t&t["Operator.Any.MissionStarted3"] = "There are People here, I will report if I find something.",&n&t&t["Sofia.MissionStarted3"] = "I will be waiting \n And remember Information from personnel will greatly help you",&n&n&t&t["Sofia.Ventplans"] = "The building plans show theres a vent in the Administration area and its connected to the vault.",&n&t&t["Operator.Any.PowerBox"] = "That should have disabled the Metal Detectors for the Workshop",&n&t&t["Operator.Any.DistractionStarted"] ="Can the Lead Programmer come down to the Security Center, we have a Server Error.",&t&n&n&t&t["Operator.Any.DistractionStarted2"] ="Can some Security come to the Armory, we got a new shipment.",&t&n&n&t&t["Operator.Any.DistractionStarted3"] ="Administration, we received some error messages from your power boxes, we will send a Technician over.",&n&n&t&t["Operator.Any.DistractionStarted4"] ="Ma'am, a new server shipment arrived in storage and i need some help carrying the servers.",&t&n&n&t&t["Operator.Any.ServerDoorRequest"] ="Sorry to bother but it seems like i lost my Server Access Badge, could you open it for me?",&t&n&n&t&t["Operator.Any.RequestAccess1"] = "I was asked by the Head Technician to bring some servers, Security ID 4-4-4-4-4",&n&n&t&t["Name.BaseSecurity"] = "Base Security",&n&t&t["Name.WorkshopTechnician"] = "Technician",&n&t&t["Name.WorkshopProgrammer"] = "Programmer",&n&t&t["Name.Janitor"] = "Janitor",&n&t&t["Name.EliteOperative"] = "Elite Operative",&n&t&t["Name.Overwatch"] = "Overwatch",&n&t&t["Name.IT"] = "IT Technician",&n&n&t&t["Prompt.DisguiseRequired"] = "Base Security Disguise Required",&n&t&t["Actor.Overwatch"] = "Base Security",&n&n&t&t["Challenge.BirdDown"] = "Bird Down",&n&t&t["Challenge.Desc.BirdDown"] = "Manipulate the gunships electronics",&n&t&t["Challenge.Hint.BirdDown"] = "EE3 Required",&n&n&t&t["Challenge.Completionist"] = "The Completionist",&n&t&t["Challenge.Desc.Completionist"] = "Collect all Optional Loot",&n&t&t["Challenge.Hint.Completionist"] = "Steal 2 cash && inject spyware",&n&n&t&t["Object.Archive"] = "Archive",&n&t&t["ItemDesc.Folder"] = "Folder with Routes and Halcyon Operative Informations",&n&t&t["Item.Folder"] = "Folder",&n&t&t["Objective.Files"] = "Files Secured",&n&n&t&t["Info"] = "Information \n (Rookie Only)",&n&t&t["InfoArchives"] = "Archive Colors",&n&t&t["Black"] = "Black = Decorational",&n&t&t["Red"] = "Red = Searchable Intel",&n&t&t["Blue"] = "Blue = Contains Items",&n&n&t&t["Objective.Weaponss"] = "Weapons",&n&t&t["VentInfo"] = "Vents",&n&t&t["VentBreak"] = "Use Blowtorch to open",&n&n&t&t["Challenge.VentChallenge"] = "Staying Clean",&n&t&t["Challenge.Desc.VentChallenge"] = "Do not use the vents",&n&t&t["Challenge.Hint.VentChallenge"] = "Do not use the vents",&n&n&t&t["Challenge.BadgeHunter"] = "Badge Hunter",&n&t&t["Challenge.Desc.BadgeHunter"] = "Collect all Badges",&n&t&t["Challenge.Hint.BadgeHunter"] = "Collect all Badges",&n&n&t&t["Challenge.NoKills"] = "Clean hands",&n&t&t["Challenge.Desc.NoKills"] = "Do not kill anyone",&n&t&t["Challenge.Hint.NoKills"] = "Do not kill anyone",&n&t&t["Dialogue.TruckComingIn"] = "Send Head Programmer to Security Office",&n&t&t["UI.ClearBasement"] = "Send Head Programmer to Security Office",&n&n&t&t["Objective.USBKeyInsert"] = "Insert USB",&n&t},&t&n&tCustomDisguises = {&n&t&tCustomDisguise = {&n&t&t&tName = "Name.BaseSecurity",&n&t&t&tOutfits = {&n&t&t&t&t{11138112522, 3958274022},&n&t&t&t}&n&t&t},&n&t&tCustomDisguise2 = {&n&t&t&tName = "Name.WorkshopTechnician",&n&t&t&tOutfits = {&n&t&t&t&t{386296502, 386304405},&n&t&t&t}&n&t&t},&n&t&tCustomDisguise3 = {&n&t&t&tName = "Name.WorkshopProgrammer",&n&t&t&tOutfits = {&n&t&t&t&t{59823810, 7825739},&n&t&t&t}&n&t&t},&n&t&tCustomDisguise4 = {&n&t&t&tName = "Name.Janitor",&n&t&t&tOutfits = {&n&t&t&t&t{530412367, 530412536},&n&t&t&t}&n&t&t},&n&t&tCustomDisguise5 = {&n&t&t&tName = "Name.IT",&n&t&t&tOutfits = {&n&t&t&t&t{129360389261053, 108024337580860},&n&t&t&t},&n&t&t},&n&t},&n&n&tDialogueTree = {&n&t&tAltRadioDialogueTree = {&n&t&t&tCancelText = "UI.StopUsing",&n&t&t}&n&t},&n}fcbcbbfcbdbbgcbfd-};~~.b@kx.b-kw.bb.bb.bbfbcg.bpbb-~~w'.bpbbk.bm$qfbgbgbfbhbjfbkbmbbgcbpd-|&rk.b3j--~,X>.bb(G,-~}fbdg-~~H&-~~p$.bb]Tk~~m$qfbfbhbqgbrbbbgcbtd-|j`}.b#Mm.c?.?.bb4bb.bbfbfg.bvbb.bbbb.bvbbk.bmhqfbfbvbwgbxbhbhbgfbyb3fb4b6fb7b8bbgcb9d-|H4W.b3^r-~BcP.bb,($.bbfbdg-~~%9.bbPJ.bbY6k~~m$qfbfb!b"gbrbbbgcb9d-|[,;.b(^r-}],J.bbM~~.bbfbdg-~~%9.bbPJ.bbY6k~~m$qfbfb!b"gbrbbbgcb9d-|9ym.b3^r.bgv{bbbC=Bbbbfbdg-~~%9.bbPJ.bbY6k~~m$qfbfb!b"gbrbbbgcb9d-|&4-.b3^r-~.3!.bb%bb-~}fbdg-~~%9.bbPJ.bbY6k~~m$qfbfb!b"gbrbbbgcb#d-{}g8.b'X#.c%'&bbb.bbbbbfbhg.bbCT.bjw'.bqbbk~~m$qfbfb$bqfb%bqgb&bfb'bqhb(bjfbhbqfb)b*bbgcb+d-|+.b.b&H'-}w]T.bb4bb.bbfbfg.bcbb.bdw'.bc?wk~~m$qfbfb,b-fb.b/fb:b;kb<bbbbbbfb=b>fb?b@gbBbfbCb-bcccbgcb#d-{}g8.b'X9.cy'&bbb.bbbbbfbhg.bbCT.bjw'.bqbbk~~m$qfbfb$bqfb%bqgb&bfb'bqhb(bjfbhbqfb)b*bbgcbDd-{}Hr.b'QT-~7q)bbb.bbbbbfbcg.bc]T.bg8?.bh?wk~~m$qfbfbhbqbbgcbDd-|b;$.b'QT-}\D(.bbM~~.bbfbcg.bc]T.bg8?