eletedDialogue = {{"Sophie.Delete","Jimmy.Delete"}},&n&t&tServerOption = {{"Sofia.Server"}},&n&t&tVentLocationFound = {{"Sofia.Ventplans"}},&n&t&tPowerBoxTech = {{"Operator.Any.PowerBox"}},&n&t&tTakeDown1 = {{"Sofia.TakeDown1"}},&n&t&tTakeDown2 = {{"Sofia.TakeDown2"}},&n&t&tTakeDown3 = {{"Sofia.TakeDown3"}},&n&n&t&tVaultDialouge = {{"Operator.Any.Vault1","Sofia.Any.Vault1"}},&n&n&t&tSecret = {&n&t&t&t{"Operator.Any.Secret1","Sofia.Secret1","Operator.Any.Secret2","Sofia.Secret2","Operator.Any.Secret3"}&n&t&t},&n&n&n&t&tLoreInspected = {{"Operator.Any.Lore1","Sofia.Lore1","Operator.Any.Lore2","Sofia.Lore2","Operator.Any.Lore3","Sofia.Lore3","Jackdaw.Lore4","Operator.Any.Lore4","Jackdaw.Lore5","Operator.Any.Lore5"&n&t&t}}&n&t},&n&n&tCustomStrings = {&n&t&t["MissionTitle.MyCoolMission"] = "Operation: Silent Hand",&n&t&t["MissionDescription.MyCoolMission"] = "After the events of the Withdrawal, Jackdaw decided to go on a mission of his own for a few months. Who did he let in charge? None other than Sparrow, with her in Charge she sent the Freelancer on a mission with the Title “Operation: Silent Hand” to retrieve old files from an abandoned Halcyon Facility, but not everything goes to plan…",&n&t&t["StartingLocationTitle.EntryPoints"] = "Entrance",&n&t&t["StartingLocation.Title1"] = "Entrance",&n&t&t["StartingLocation.Title1.Desc"] = "Spawn at the Entrance next to the Van",&n&t&t["StartingLocation.Vent"] = "Vent",&n&t&t["StartingLocation.Vent.Desc"] = "Spawn inside the Vents",&n&t&t["StartingLocation.Maintenance"] = "Old Maintence Tunnel",&n&t&t["StartingLocation.Maintenance.Desc"] = "Spawn in the old maintenace tunnel (Forced Loud)",&n&t&t["StartingLocation.BankTruck"] = "Bank Truck",&n&t&t["StartingLocation.BankTruck.Desc"] = "Spawn next to the Bank Truck with Base Security Disguise and opened Bank Truck",&n&n&t&t["StartingLocation.Title2"] = "Entrance (Nightmare Mode)",&n&t&t["StartingLocation.Title2.Desc"] = "Spawn at the Entrance (Forced Hard Loud)",&n&t&t["StartingLocation.VentNightmare"] = "Vent (Nightmare Mode)",&n&t&t["StartingLocation.VentNightmare.Desc"] = "Spawn inside the Vents (Forced Hard Loud)",&n&t&t["StartingLocation.MaintenanceNightmare"] = "Old Maintence Tunnel (Nightmare Mode)",&n&t&t["StartingLocation.MaintenanceNightmare.Desc"] = "Spawn in the old maintenace tunnel (Forced Hard Loud)",&n&n&t&t["Tooltip.RequiresSkillVent"] = "Required Skills: Inconspicuous III && Electrical Engineering II",&n&t&t["Tooltip.RequiresSkillMaintence"] = "Required Skills: Climber II && Brute Strength II",&n&t&t["Tooltip.RequiresSkillBankTruck"] = "Required Skills: Intimidation III && SocialEngineering III",&n&n&t&t["Objective.WaitForHack"] = "Wait for the Hackers to Override elevator",&n&t&t["Operator.Any.Lore1"] ="Hey uh, Sparrow?",&n&t&t["Sofia.Lore1"] = "Ye, what's up?",&n&t&t["Operator.Any.Lore2"] ="Can u put Jackdaw on the line?",&n&t&t["Sofia.Lore2"] = "Wha- Why?",&n&t&t["Operator.Any.Lore3"] ="Let's just say, we might have a pretty big problem...",&n&t&t["Sofia.Lore3"] = "Fine, i will have him here give me a moment",&n&t&t["Jackdaw.Lore4"] ="Ugh why are u calling me at 2AM, did u forget I am in Berlin?",&n&t&t["Operator.Any.Lore4"] ="Sorry, but u might want to see this 'Sends photo of Military Involvement'",&n&t&t["Jackdaw.Lore5"] ="Well that isn't good, tell me if u can find out more, now let me damn sleep",&n&t&t["Operator.Any.Lore5"] ="Ye alr, i will try to find more Intel on this. Over",&n&t&t["Action.Inspect"] = "Inspect",&n&t&t["Objective.Inspect"] = "Inspect Window",&n&t&t["Objective.Archive"] = "Search Archives",&n&n&t&t["Sophie.Delete"] = "Hey. Why did our ram usage jump from 20% to 80%?",&n&n&t&t["Sofia.TakeDown1"] = "You do know they see each other on a daily basis, right? \n Don't take out too many people",&n&t&t["Sofia.TakeDown2"] = "Perhaps start slowing down \n They will notice their people going missing",&n&t&t["Sofia.TakeDown3"] = "Take one more out, and the entire building goes into lockdown",&n&n&n&t&t["Jimmy.Delete"] = "I don't know, but i think this is above our paygrade \n So i could care less abt this",&n&t&t["Notify.Takedown"] = "Too many employees went missing",&n&n&t&t["Title.Falcon"] = "Falcon",&n&t&t["Title.Servers"] = "Armory",&n&t&t["Title.ServerSearch"] = "Search Servers",&n&t&t["Title.ServerFound"] = "Found Server",&n&t&t["Title.ServerDelete"] = "Inject Spyware (AP 3)",&n&t&t["Title.ServerDeleted"] = "Injected Spyware",&n&n&t&t["Operator.Any.CustomDialogue"] = "This is a custom dialogue string",&n&t&t["Speaker.Sofia"] = "Sparrow",&n&t&t["Speaker.Jackdaw"] = "Jackdaw",&n&t&t["Speaker.Rose1"] = "???",&n&t&t["Speaker.Rose2"] = "Rachael",&n&t&t["Speaker.Narrator"] = "Narrator",&n&t&t["Speaker.Sophie"] = "Sophie IT",&n&t&t["Speaker.Jimmy"] = "Jimmy IT",&n&t&t["Title.Freelancer"] = "Freelancer",&n&t&t["Title.Freelancer2"] = "Field Operative",&n&t&t["Title.TakeDown"] = "Takedown Limit",&n&n&t&t["Objective.MissionText5"] = "",&n&t&t["Objective.Weapons"] = "Weapons Secured",&n&n&t&t["Objective.MissionText6"] = "",&n&t&t["Objective.Servers"] = "Server Downloaded",&n&n&t&t["HeadITIntel"] = "Head IT Technician",&n&t&t["ArmoryGuard"] = "Armory Badge",&n&n&t&t["Title.Wren"] = "Wren",&n&t&t["Title.Wren2"] = "Field Operative",&n&n&t&t["Title.Thunder"] = "Thunder",&n&t&t["Title.Thunder2"] = "Field Operative",&n&n&t&t["Title.Rose"] = "Rose",&n&t&t["Title.Rose2"] = "Field Operative",&n&n&t&t["Title.Tech"] = "Techroom",&n&t&t["Title.Tech2"] = "Technicians and Engineers ONLY",&n&t&t["Title.Tech3"] = "NO WEAPONS PAST THIS POINT",&n&n&t&t["Title.Storage"] = "Storage",&n&n&t&t["Title.Offices"] = "Offices",&n&n&t&t["Title.Security"] = "Security",&n&n&t&t["Title.Maintence"] = "Maintenence",&n&n&t&t["Title.EliteOps"] = "Elite Operations Center",&n&t&t["Title.EliteOpsBreakRoom"] = "Elite Operations Break Room",&n&n&t&t["Title.Workshop"] = "Workshop",&n&n&t&t["Title.LoadingBay"] = "Loading Bay",&n&n&t&t["Title.ShootingRange"] = "Shooting Range",&n&n&t&t["Objective.MissionText2"] = ""